---
const target = "/?assignment=portrait";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portraits</title>
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <script is:inline>
      window.location.replace("/?assignment=portrait");
    </script>
  </head>
  <body style="background:#000;color:#f8f8f8;font-family:sans-serif;display:grid;place-items:center;min-height:100vh;margin:0;">
    <p>Redirecting to <a href={target} style="color:#f8f8f8;">Portraits</a>...</p>
  </body>
</html>
